# Environment
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.venv/
*.egg-info/

# ML model weight artifacts (never the app/models ORM package)
*.pkl
*.h5
*.pt
# Ignore the directory's contents (not the dir itself, so the one file below
# can be re-included — git can't un-ignore inside a fully excluded dir).
ml/models/*
# ...except the tiny BlazeFace detector asset (229 KB), which the pipeline
# requires at runtime and has no other delivery path. DeepFace/EasyOCR weights
# still auto-download; only this one must ship with the code.
!ml/models/blaze_face_short_range.tflite

# Datasets: keep the folder skeleton (.gitkeep / README), never the images
data/**/*.png
data/**/*.jpg
data/**/*.jpeg
data/**/*.bmp

# Database
*.db
*.sqlite

# Uploads and outputs
uploads/
faiss_index/

# Python tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/

# ML experiment tracking
mlruns/
mlartifacts/

# VS Code
.vscode/

# OS
.DS_Store
Thumbs.db

#personal Info (real ID images — never commit)
docs/Identifiers/testImages/
docs/identifiers/testImages/
