# --- Application ---
APP_NAME=KYC-API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security (generate strong values for production) ---
# With ENVIRONMENT=production the app refuses to start unless SECRET_KEY,
# API_KEY_PEPPER and ENCRYPTION_KEY are all set to real values of at least
# 32 bytes. Generate the first two with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY_PEPPER=change-me-in-production

# Consecutive failed logins before an account is locked, and for how long.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# AES-256 key sealing the PII columns (NFR03/NFR04). Required in every
# environment — there is no default, because a key shared by every checkout
# would be no protection, and dev databases hold real ID data too. Generate:
#   python -c "from app.core.crypto import generate_key; print(generate_key())"
# Must also be set when running `alembic upgrade`. Rotating it makes existing
# encrypted rows unreadable — see docs/DASHBOARD-BACKEND.md §10 first.
ENCRYPTION_KEY=

# --- Database ---
DATABASE_URL=postgresql+psycopg://kyc:kyc@localhost:5432/kyc

# --- Pipeline thresholds (tunable) ---
FACE_MATCH_THRESHOLD=0.40
LIVENESS_THRESHOLD=0.50
DUPLICATE_THRESHOLD=0.70
PIPELINE_TIMEOUT_SECONDS=10

# --- Storage paths ---
FAISS_INDEX_PATH=faiss_index/index.faiss
ANTISPOOF_MODEL_PATH=models/antispoof_svm.pkl

# --- CORS (Streamlit dashboard origin) ---
CORS_ORIGINS=["http://localhost:8501"]

# --- Subscription enforcement ---
QUOTA_WARNING_RATIO=0.80
